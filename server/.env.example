# ── Required ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# On Railway: set this to ${{Postgres.DATABASE_URL}} (Railway fills it in automatically).
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/buildright

# Admin panel password — change this before deploying.
ADMIN_PASSWORD=change-me-before-deploying

# ── Set by Railway automatically (do not set these manually) ──────────────────
# PORT is injected by Railway — the server reads process.env.PORT.
# PORT=3001

# ── Required in production ─────────────────────────────────────────────────────
# Tell Express it is running in production (enables static file serving, etc.)
NODE_ENV=production

# ── Optional ───────────────────────────────────────────────────────────────────
# Only needed if you deploy the frontend separately from the backend.
# If the frontend is served by this Express server, leave this unset.
# CLIENT_URL=https://your-frontend.up.railway.app
